# Copy file ini menjadi .env di komputer lokal.
# Jangan commit file .env yang berisi password/token.

SIGA_WEB_BASE_URL=https://newsiga-siga.bkkbn.go.id
SIGA_API_BASE_URL=https://siga-api-gateway.bkkbn.go.id

SIGA_USERNAME=
SIGA_PASSWORD=
SIGA_APP_ID=2

AGENT_DRY_RUN=true
AGENT_REQUIRE_APPROVAL=true
AGENT_LOG_LEVEL=INFO
AGENT_HEADLESS=false
AGENT_KEEP_BROWSER_OPEN=true
AGENT_CLOSE_DELAY_MS=0
AGENT_BROWSER_PROFILE=.browser-profile/siga

CHROME_EXE=C:\Program Files\Google\Chrome\Application\chrome.exe

INPUT_DIR=data/input
OUTPUT_DIR=data/output
LOG_DIR=logs
